rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (uid)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - email: string (required) - The user's email address.
    //   - displayName: string (optional) - The user's display name.
    //   - photoURL: string (optional) - The user's profile picture URL.
    //   - role: string (required, enum: ['user', 'admin']) - The user's role.
    //   - createdAt: timestamp (required) - When the user profile was created.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
         (request.auth.token.email == "m.ngwako63ent@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidEnrollment(data) {
      return data.keys().hasAll(['courseId', 'enrolledAt', 'progress', 'completedModules']) &&
             data.courseId is string &&
             data.enrolledAt is string &&
             data.progress is number &&
             data.completedModules is list;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() < 100 &&
             data.role in ['user', 'admin'] &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
      allow delete: if isAdmin();

      match /enrollments/{courseId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidEnrollment(request.resource.data);
        allow update: if isOwner(userId) && isValidEnrollment(request.resource.data);
        allow delete: if isAdmin();
      }
    }
  }
}
